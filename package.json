{
  "name": "mermaid-canvas-editor",
  "version": "0.1.2",
  "description": "Mermaid, Markdown, and canvas desktop editor.",
  "author": "Mermaid Canvas Editor",
  "private": true,
  "main": "electron/main.cjs",
  "desktopName": "mermaid-canvas-editor.desktop",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "ready": "bash scripts/ready.sh",
    "mmm": "node --import tsx src/cli/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "themes:generate": "node --import tsx scripts/generate-kitty-themes.ts",
    "electron:rebuild": "electron-rebuild -f -w node-pty",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build": "node scripts/electron-build.mjs",
    "electron:ship": "node scripts/electron-ship.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:ship": "node scripts/desktop-ship.mjs",
    "desktop:dev": "npm run electron:dev",
    "desktop:build": "npm run electron:build --",
    "desktop:ship": "npm run electron:ship --",
    "windows:run": "node scripts/run-on-windows.mjs",
    "windows:install": "node scripts/run-on-windows.mjs --install-only",
    "windows:launch": "node scripts/run-on-windows.mjs --launch-only",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/maple-mono": "^5.2.6",
    "@gsap/react": "^2.1.2",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/preset-gfm": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@radix-ui/react-collapsible": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tauri-apps/api": "^2.11.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-shape": "^3.2.0",
    "font-list": "^2.1.0",
    "gsap": "^3.15.0",
    "iconoir-react": "^7.11.0",
    "konva": "^9.3.20",
    "mermaid": "^11.4.1",
    "node-pty": "^1.1.0",
    "pixi.js": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/d3-shape": "^3.1.8",
    "@types/jsdom": "^28.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "commander": "^7.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.19.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "app.mermaid-canvas-editor.desktop",
    "productName": "Mermaid Canvas Editor",
    "directories": {
      "output": "dist-electron"
    },
    "artifactName": "mermaid-canvas-editor-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/font-list/libs/**"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icons/icon.png",
      "category": "Development",
      "syncDesktopName": true
    }
  }
}
