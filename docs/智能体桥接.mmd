%% Pi Agent 与编辑器实时文档桥接
flowchart LR
  subgraph Surface[独立工作表面]
    AgentPanel["Pi Agent 浮动面板<br/>shadcn Chat / 控制中心"]
    TerminalPanel["终端浮动面板<br/>xterm / node-pty"]
    OfflineCli["离线 mmm CLI<br/>read / validate / diff / patch / layout / fixture"]
  end

  subgraph Renderer[React 编辑器]
    SessionHook["useAgentSession<br/>RPC 流 / 交互请求"]
    DocumentBridge["实时文档适配<br/>revision / selection / references"]
    EditorState["打开的主文档与 Markdown 窗口"]
    UndoSave["单次 undo 事务<br/>可选自动保存"]
  end

  subgraph Electron[Electron 边界]
    Preload["contextBridge IPC"]
    Manager["Pi Agent Manager<br/>每窗口 Worker / 会话所有权"]
    Worker["Pi SDK Worker<br/>官方 JSONL RPC"]
    Safety["安全扩展<br/>信任 / 风险确认 / 打开文档保护"]
    Pty["Terminal Manager<br/>独立 PTY 生命周期"]
  end

  subgraph Pi[Pi 原生能力]
    Sessions["JSONL Sessions / tree / fork"]
    Models["Providers / OAuth / API Key / Models"]
    Resources["Tools / Skills / Extensions / Prompts / Packages"]
    Settings["Global + Project settings"]
  end

  AgentPanel --> SessionHook --> Preload --> Manager --> Worker
  Worker --> Safety
  Worker --> Sessions
  Worker --> Models
  Worker --> Resources
  Worker --> Settings
  Worker -->|document.list/read/apply/reveal| DocumentBridge
  DocumentBridge --> EditorState
  DocumentBridge --> UndoSave
  TerminalPanel --> Preload --> Pty
  OfflineCli -->|只处理磁盘文件| EditorState
