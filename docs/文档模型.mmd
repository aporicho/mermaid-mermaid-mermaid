%% 文档模型与源码同步
flowchart LR
  subgraph PersistedFile[持久化文件]
    direction TB
    DiskFile[".mmd / .mermaid 文件"]
    Source["Mermaid 源码"]
    Layout["%% canvas-layout<br/>位置 / 视口 / 路由 / 主题"]
    AssetSrc["asset.src<br/>可迁移相对路径"]
  end

  subgraph LoadPipeline[加载与解析]
    direction TB
    StripLayout["stripCanvasLayout"]
    ParseMermaid["parseMermaid"]
    ApplyLayout["applyLayout"]
    DetectKind["识别图类型<br/>可编辑 / 只渲染"]
  end

  subgraph RuntimeModel[运行时模型]
    direction TB
    Graph["MermaidGraph<br/>节点 / 连线 / 分组 / 资源"]
    EditorState["EditorState<br/>选择 / 历史 / 过滤"]
    WorkspaceView["工作区视图<br/>无限画布 / 渲染 / 源码"]
    Viewport["ViewportState"]
    Draft["编辑器草稿状态"]
  end

  subgraph BuildPipeline[写回与渲染]
    direction TB
    Serialize["serializeMermaid"]
    LayoutFromGraph["layoutFromGraph"]
    BuildDocument["buildMermaidDocument"]
    MermaidRender["官方 Mermaid render"]
  end

  DiskFile --> Source
  Source --> StripLayout
  Source --> Layout
  StripLayout --> DetectKind
  DetectKind -->|flowchart| ParseMermaid
  DetectKind -->|其他 Mermaid 类型| MermaidRender
  ParseMermaid --> Graph
  Layout --> ApplyLayout
  Graph --> ApplyLayout
  ApplyLayout --> Graph
  Layout --> Viewport
  Graph --> EditorState
  EditorState --> Draft
  EditorState --> WorkspaceView

  Graph --> Serialize
  Graph --> LayoutFromGraph
  Viewport --> LayoutFromGraph
  LayoutFromGraph --> BuildDocument
  Serialize --> BuildDocument
  BuildDocument --> DiskFile
  Source --> MermaidRender
  Source --> WorkspaceView
  AssetSrc --> Graph
