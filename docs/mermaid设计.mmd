flowchart LR
  subgraph HumanSide [人类侧：Mermaid 编辑器和查看器]
    Human@{ shape: stadium, label: "人类" }
    WebUI@{ shape: rounded, label: "WebUI" }
    SourcePanel@{ shape: rect, label: "源码面板" }
