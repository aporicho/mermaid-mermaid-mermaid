%% Mermaid Canvas Editor system overview
%% Keep this file as the compact top-level map. Detailed mechanics live in the topic diagrams.
flowchart LR
  subgraph UserSurfaces[用户工作表面]
    direction TB
    Human["人类用户"]
    SourcePanel["源码面板"]
    ProjectBrowser["项目文件浏览器"]
    CanvasView["无限画布"]
    RenderView["Mermaid 预览"]
    Inspector["属性 / 主题 / 诊断"]
  end

  subgraph EditorRuntime[React 编辑器运行层]
    direction TB
    Orchestrator["Editor Orchestrator<br/>mermaid-editor.tsx"]
    CommandTx["Command / Transaction<br/>interaction/commands.ts<br/>interaction/transaction.ts"]
    CanvasEngine["Canvas Engine<br/>Konva + geometry + visual state"]
    MermaidEngine["Mermaid Engine<br/>parse / serialize / render"]
    ThemeCompiler["Theme Compiler<br/>CSS / Canvas / Mermaid adapters"]
  end

  subgraph Truth[共同事实源]
    direction TB
    MermaidSource["Mermaid source"]
    LayoutComment["canvas-layout comment<br/>viewport / positions / routing / theme"]
    GraphModel["MermaidGraph<br/>nodes / edges / subgraphs / assets"]
    EditorState["Editor state<br/>selection / history / draft / filters"]
    ProjectWorkspace["ProjectWorkspace<br/>root / file list / query"]
  end

  subgraph PlatformBoundary[平台能力边界]
    direction TB
    RuntimeAdapter["Runtime Adapter<br/>editor-runtime.ts"]
    BrowserRuntime["Browser runtime<br/>File picker / download / localStorage"]
    TauriNative["Tauri native layer<br/>files / project scan / app state / assets / bridge"]
    WindowsFlow["Windows packaging flow<br/>WSL sync -> desktop:ship -> launch"]
  end

  subgraph AiCli[AI 与 CLI]
    direction TB
    OfflineCli["Offline file CLI<br/>read / validate / diff / patch / layout / fixture"]
    LiveBridge["Live desktop bridge<br/>ping / context / apply"]
    Agent["AI Agent"]
  end

  subgraph QualityRails[质量与性能护栏]
    direction TB
    Performance["Performance rails<br/>hot / commit / heavy paths"]
    Contracts["Contract tests<br/>model / interaction / runtime boundaries"]
    ReleaseChecks["Acceptance<br/>ready / build / windows:run"]
  end

  Human --> SourcePanel
  Human --> ProjectBrowser
  Human --> CanvasView
  Human --> RenderView
  Human --> Inspector

  SourcePanel -->|text edit| Orchestrator
  CanvasView -->|pointer / wheel / gesture| CanvasEngine
  Inspector -->|commands| Orchestrator
  Orchestrator --> CommandTx
  CommandTx -->|graph commits| GraphModel
  CommandTx -->|history / selection / filters| EditorState

  MermaidSource -->|load| MermaidEngine
  MermaidEngine -->|editable flowchart| GraphModel
  MermaidEngine -->|render-only diagrams| RenderView
  GraphModel -->|serialize| MermaidSource
  LayoutComment -->|apply layout| GraphModel
  GraphModel -->|derive layout| LayoutComment

  GraphModel --> CanvasEngine
  CanvasEngine --> CanvasView
  MermaidSource --> MermaidEngine
  MermaidEngine --> RenderView
  ThemeCompiler -->|CSS variables| UserSurfaces
  ThemeCompiler -->|canvas tokens| CanvasEngine
  ThemeCompiler -->|themeVariables| MermaidEngine

  Orchestrator --> RuntimeAdapter
  Orchestrator --> ProjectWorkspace
  ProjectBrowser -->|open project file| Orchestrator
  RuntimeAdapter --> BrowserRuntime
  RuntimeAdapter --> TauriNative
  TauriNative --> WindowsFlow
  RuntimeAdapter -->|open / save / draft / image display URL| Truth

  OfflineCli -->|shared document logic| MermaidEngine
  OfflineCli -->|file patch output| MermaidSource
  Agent --> OfflineCli
  Agent --> LiveBridge
  LiveBridge -->|token loopback bridge| TauriNative
  TauriNative -->|context / apply command / result| Orchestrator

  Performance -.-> CanvasEngine
  Performance -.-> CommandTx
  Contracts -.-> MermaidEngine
  Contracts -.-> RuntimeAdapter
  ReleaseChecks -.-> PlatformBoundary
