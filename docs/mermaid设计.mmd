    ThemePanel@{ shape: rect, label: "主题设置" }
    UserFeedback@{ shape: doc, label: "用户反馈" }
  end
  subgraph CoreSide [编辑器底层：把 GUI 行为稳定落到 Mermaid]
    EditorCore@{ shape: rect, label: "编辑器核心状态" }
    ParserSerializer@{ shape: rect, label: "解析与序列化" }
    InteractionLayer@{ shape: rect, label: "交互状态层" }
    GeometryRouting@{ shape: rect, label: "节点几何与连线路由" }
    VisualTheme@{ shape: rect, label: "主题与视觉 token" }
  end
  subgraph TruthSide [共同事实源：AI 和人看到同一份结构]
    MermaidFile@{ shape: doc, label: "Mermaid 文件" }
    LayoutComment@{ shape: doc, label: "canvas-layout 注释" }
    BrowserState@{ shape: cyl, label: "浏览器本地状态" }
  end
  subgraph AiSide [AI 侧：CLI 只围绕 Mermaid 文件工作]
    Agent@{ shape: hex, label: "AI Agent" }
    CLI@{ shape: rounded, label: "CLI" }
    ReadCurrent@{ shape: rect, label: "查看当前图" }
    DiffChanges@{ shape: rect, label: "对比前后变化" }
    PatchMermaid@{ shape: rect, label: "修改 Mermaid" }
    ValidateRender@{ shape: rect, label: "校验与预览" }
  end
  subgraph ProjectSide [项目执行侧：AI 根据图的反馈落地修改]
    ProjectTasks@{ shape: rect, label: "执行任务" }
    Codebase@{ shape: docs, label: "项目代码" }
  end
  Human -->|查看、理解、调整| WebUI
  Human -->|提出反馈| UserFeedback
  UserFeedback -->|反馈意图| Agent
  WebUI --> SourcePanel
  WebUI --> CanvasView
  WebUI --> RenderView
  WebUI --> Inspector
  WebUI --> ThemePanel
  SourcePanel -->|直接编辑 Mermaid| ParserSerializer
  CanvasView -->|拖拽、连线、对齐| InteractionLayer
  Inspector -->|修改节点和连线属性| EditorCore
  ThemePanel -->|修改 shadcn 和画布 token| VisualTheme
  MermaidFile -->|源码渲染| RenderView
  EditorCore --> ParserSerializer
  EditorCore --> InteractionLayer
  EditorCore --> GeometryRouting
  EditorCore --> VisualTheme
  ParserSerializer -->|读写结构| MermaidFile
  GeometryRouting -->|保存人类画布布局| LayoutComment
  CanvasView -->|只服务人类空间整理| LayoutComment
  WebUI -->|文件句柄、折叠状态、临时草稿| BrowserState
  WebUI -->|打开与保存| MermaidFile
  MermaidFile -->|AI 所见就是用户所见| CLI
  CLI --> ReadCurrent
  CLI --> DiffChanges
  CLI --> PatchMermaid
  CLI --> ValidateRender
  ReadCurrent --> Agent
  DiffChanges --> Agent
  ValidateRender --> Agent
  Agent -->|需要调整图时| PatchMermaid
  PatchMermaid -->|写回同一份 Mermaid| MermaidFile
  Agent -->|根据图和反馈拆解工作| ProjectTasks
  ProjectTasks -->|修改、验证、提交| Codebase
  Codebase -->|结构变化需要同步| Agent
  LayoutComment -.->|AI 可忽略布局细节| CLI
