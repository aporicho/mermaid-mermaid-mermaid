{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mermaid Canvas Editor",
  "version": "0.1.0",
  "identifier": "app.mermaid-canvas-editor.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mermaid Canvas Editor",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "fileAssociations": [
      {
        "ext": ["mmd", "mermaid"],
        "name": "Mermaid Diagram",
        "description": "Mermaid diagram source file",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": ["canvas.json"],
        "name": "MMM Canvas",
        "description": "MMM infinite canvas document",
        "role": "Editor",
        "mimeType": "application/json"
      }
    ],
    "shortDescription": "Mermaid editor and AI collaboration canvas",
    "longDescription": "A Mermaid editor, viewer, infinite canvas, and local AI bridge for real-time diagram collaboration."
  }
}
